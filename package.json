{
  "name": "mana-ts",
  "version": "1.0.2",
  "description": "A high-performance, O(1) reactive state engine and type-governance ecosystem for deeply nested trees.",
  "keywords": [
    "react"
  ],
  "homepage": "https://github.com/The64bitdude/mana#readme",
  "bugs": {
    "url": "https://github.com/The64bitdude/mana/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/The64bitdude/mana.git"
  },
  "license": "MIT",
  "author": "Bryce Gredig",
  "type": "module",
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/*"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build --clean && tsc --build",
    "examples": "cd examples&&npm run test"
  },
  "dependencies": {
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "typescript": "^6.0.3"
  }
}
